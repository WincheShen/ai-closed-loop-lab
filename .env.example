# =============================================================================
# AI Closed Loop Lab — Environment Configuration
# =============================================================================

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
XAI_API_KEY=...

# Azure OpenAI (optional enterprise)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- A-Share Market Data ---
EASTMONEY_TOKEN=          # Optional: for enhanced akshare quotas
TUSHARE_TOKEN=            # Optional: tushare pro token

# --- Trading (Paper Trading / Simulation) ---
# 模拟盘模式 (mock), 或对接券商接口 (broker)
TRADING_MODE=mock
# 券商接口配置 (仅当 TRADING_MODE=broker 时生效)
BROKER_API_URL=
BROKER_API_KEY=
BROKER_SECRET=
BROKER_ACCOUNT=

# --- Social Media ---
# 小红书账号 cookies / session (由 vendor/xiaohongshu-skills 管理)
XHS_SKILLS_DIR=vendor/social_media_automation/vendor/xiaohongshu-skills

# --- Central Brain Persistence ---
DB_PATH=data/central_brain.db
VECTOR_DB_PATH=data/vector_memory.db

# --- PostgreSQL (Strategy Mining + future shared store) ---
PG_HOST=192.168.3.73
PG_PORT=5433
PG_DB=agent_data
PG_USER=admin
PG_PASSWORD=
PG_DSN=postgresql://admin:CHANGE_ME@192.168.3.73:5433/agent_data

# --- WeChat Official Account Crawler (strategy_mining) ---
# (a) 公众号后台登录态（用于列出某公众号历史文章 URL）
#     来源：https://mp.weixin.qq.com/ 后台 F12
WX_MP_TOKEN=
WX_MP_COOKIE=

# (b) 微信客户端登录态（用于拉文章阅读量/点赞/评论/评论图片）
#     来源：PC 微信 + mitmproxy/Charles 抓 /mp/getappmsgext 请求
#     详见 docs/strategy_mining.md 抓包指引
WX_APPMSG_TOKEN=
WX_CLIENT_COOKIE=

# --- System ---
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai
DATA_DIR=data
RESULTS_DIR=reports
